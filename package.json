{
  "name": "pika-boo",
  "version": "0.1.0",
  "description": "Pika-Boo is a Windows desktop reminder app that makes calendar events hard to miss.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:ts\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on dist-electron/electron/main.js http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js",
    "prepare": "husky",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "lint": "npm run build",
    "smoke": "npm run build && node scripts/smoke.js",
    "package:dir": "npm run build && node scripts/package-win.js dir",
    "package:smoke": "npm run package:dir && node scripts/package-smoke.js",
    "package:installer": "npm run build && node scripts/package-win.js installer",
    "package:installer:smoke": "npm run package:installer && node scripts/installer-smoke.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhijeetkakade1234/Pika-Boo.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/abhijeetkakade1234/Pika-Boo/issues"
  },
  "homepage": "https://github.com/abhijeetkakade1234/Pika-Boo#readme",
  "build": {
    "appId": "com.abhijeetkakade.pikaboo",
    "productName": "Pika-Boo",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "icon": "electron/assets/pika-boo-logo.ico"
    },
    "nsis": {
      "installerIcon": "electron/assets/pika-boo-logo.ico",
      "uninstallerIcon": "electron/assets/pika-boo-logo.ico",
      "installerHeaderIcon": "electron/assets/pika-boo-logo.ico"
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
