{
  "name": "pika-boo",
  "version": "0.1.0",
  "description": "Pika-Boo is a Windows desktop reminder app that makes calendar events hard to miss.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:ts\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron:ts": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on dist-electron/main.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "smoke": "npm run build && node scripts/smoke.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhijeetkakade1234/Pika-Boo.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/abhijeetkakade1234/Pika-Boo/issues"
  },
  "homepage": "https://github.com/abhijeetkakade1234/Pika-Boo#readme",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
}
